generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Expense {
  id          String   @id @default(cuid())
  date        String   // YYYY-MM-DD
  amount      Float
  category    String
  description String
  createdAt   DateTime @default(now())

  @@index([date])
  @@index([category])
}
